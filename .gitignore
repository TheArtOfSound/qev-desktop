# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Secrets — site-integrity signing key. The PUBLIC key lives at
# landing/site-signer.ed25519.pub and SHOULD be committed; the PRIVATE
# key must NEVER be committed.
data/site-signer.ed25519.key
data/*.ed25519.key

# Tauri (QEV) build artifacts — everything under target/ is derived
# from the source and should not be committed. Cargo.lock IS
# committed because QEV is an application (not a library) and
# reproducible builds depend on it.
tauri-app/src-tauri/target/
tauri-app/src-tauri/pairing/target/

# Tauri gen/android contains both source (the manifest and custom
# resources we actually edit) and generated build outputs. Track the
# sources, ignore the build outputs.
tauri-app/src-tauri/gen/android/app/build/
tauri-app/src-tauri/gen/android/build/
tauri-app/src-tauri/gen/android/.gradle/
tauri-app/src-tauri/gen/android/buildSrc/build/
tauri-app/src-tauri/gen/android/app/src/main/java/com/imagineqira/qev/generated/

# Tauri schemas directory is generated from tauri.conf.json on every
# init — don't track it.
tauri-app/src-tauri/gen/schemas/

# Native QEV.app build artifacts on macOS
dist/QEV.app/Contents/MacOS/launcher
dist/QEV-Installers/
dist/vault-local/

# Test result and cache directories
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / npm (qev-cli and any other Node packages under this tree)
**/node_modules/
qev-cli/node_modules/

# macOS noise
.DS_Store
