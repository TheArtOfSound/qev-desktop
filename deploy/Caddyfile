secure.imagineqira.com {
    # Dashboard (main UI) — default route
    handle /* {
        reverse_proxy app:8506
    }

    # API routes under /api/
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy app:8001
    }

    # API docs direct access
    handle /docs {
        reverse_proxy app:8001
    }
    handle /openapi.json {
        reverse_proxy app:8001
    }
}
